SSH_TARGET=root@your-host
SSH_IDENTITY_FILE=~/.ssh/id_ed25519
PUBLIC_URL=http://your-public-ip-or-dns:53550
HOST_MODE=fresh
IDENTITY_MODE=auto

# Optional identity reuse
# IDENTITY_FILE=/home/demos/.secrets/demos-mnemonic

# Optional monitoring
MONITORING_PROFILE=basic
GRAFANA_ADMIN_PASSWORD=change-me

# Optional upstream overrides
BRANCH=stabilisation
# UPSTREAM_REPO=https://github.com/kynesyslabs/node.git

# Optional fixnet anchor override
# ANCHOR_PUBKEY=0x...
# ANCHOR_URL=http://node3.demos.sh:60001

# Optional recurring health monitor
# INSTALL_HEALTH_MONITOR=true
# HEALTH_CHECK_INTERVAL_MINUTES=5
# HEALTH_MAX_LAG=100
